# LLM provider: openai | openrouter | google
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_LLM__MODEL=gpt-4o-mini
OPENAI_LLM__TEMPERATURE=0.6

OPENROUTER_API_KEY=
OPENROUTER_LLM__MODEL=openai/gpt-4o-mini
OPENROUTER_LLM__API_BASE=https://openrouter.ai/api/v1
OPENROUTER_LLM__TEMPERATURE=0.6

GOOGLE_API_KEY=
GOOGLE_LLM__MODEL=gemini-2.0-flash
GOOGLE_LLM__TEMPERATURE=0.6

INTERVIEW_LLM__TEMPERATURE=0.6

INTERVIEW_SERVICE_PORT=8001

MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=app
MONGODB_PASSWORD=app
MONGODB_AUTH_SOURCE=ai_interview
MONGODB_DB_NAME=ai_interview
MONGODB_CV_ANALYSIS_COLLECTION_NAME=cv_analysis
MONGODB_CV_USER_ID_FIELD=user_id

PUBLIC_KEY=
