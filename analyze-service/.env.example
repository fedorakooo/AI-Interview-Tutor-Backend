S3_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_REGION_NAME=

RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_CV_ANALYZER_QUEUE_NAME=cv-analyze-stream
RABBITMQ_CV_ANALYSIS_RESULTS_QUEUE_NAME=cv-analysis-results
RABBITMQ_TIMEOUT=30

MONGODB_HOST=
MONGODB_PORT=
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB_NAME=
MONGODB_AUTH_SOURCE=ai_interview
MONGODB_CV_ANALYSIS_COLLECTION_NAME=
MONGODB_ROOT_USER=
MONGODB_ROOT_PASSWORD=

# LLM provider: openai | openrouter | google
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_LLM__MODEL=gpt-4o-mini
OPENAI_LLM__TEMPERATURE=0.6

OPENROUTER_API_KEY=
OPENROUTER_LLM__MODEL=openai/gpt-4o-mini
OPENROUTER_LLM__API_BASE=https://openrouter.ai/api/v1
OPENROUTER_LLM__TEMPERATURE=0.6

GOOGLE_API_KEY=
GOOGLE_LLM__MODEL=gemini-2.0-flash
GOOGLE_LLM__TEMPERATURE=0.6

ANALYZE_LLM__TEMPERATURE=0.2

DOCLING_DO_OCR=true
DOCLING_DO_TABLE_STRUCTURE=true
