MONGODB_MESSAGES_COLLECTION_NAME=messages
MONGODB_ROOT_USER=root
MONGODB_ROOT_PASSWORD=root

S3_ACCESS_KEY=test
S3_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localstack:4566
S3_BUCKET_NAME=cv-uploads
S3_REGION_NAME=us-east-1
