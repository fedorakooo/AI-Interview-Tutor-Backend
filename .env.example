ENVIRONMENT=development
DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Provider: openai | openrouter | google
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_LLM__MODEL=gpt-4o-mini
